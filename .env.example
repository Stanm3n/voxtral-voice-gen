# ── Voxtral Voice Gen — Configuration ─────────────────────────────────────────

# ── LLM (Pluggable AI Backend — Optional for Test Mode) ──────────────────────
# The Voxtral Voicebot supports any OpenAI-compatible API backend.
# If you don't use a local LLM, Voxtral remains a high-quality TTS generator.

# [OPTION A] Cloud API — Best for testing (DeepSeek / OpenRouter)
LLM_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-key-here

# [OPTION B] Local LM Studio 
# LLM_URL=http://localhost:1234/v1
# LLM_MODEL=/model
# LLM_API_KEY=lm-studio

# ── TTS (Voxtral via vLLM-Omni Docker) ───────────────────────────────────────
# The base URL for the Voxtral TTS /audio/speech endpoint
VOXTRAL_URL=http://localhost:8002/v1
VOXTRAL_MODEL=/model
# Available voices: casual_male, calm_female, de_male
VOXTRAL_VOICE=casual_male
# GPU Index for Docker (0 is first card)
TTS_GPU_ID=0

# ── STT (faster-whisper, host process) ───────────────────────────────────────
# Device ('cuda' or 'cpu') and GPU index
WHISPER_DEVICE=cuda
WHISPER_GPU_INDEX=0

# ── System Prompt (Persona) ──────────────────────────────────────────────────
# Defines the AI's behavior in Test Mode. Short and natural is best.
SYSTEM_PROMPT=You are a concise, helpful voice assistant. Keep responses short and natural for speech. Avoid markdown and special characters since your output will be spoken aloud.
